<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Module 2 | Let’s talk skincare - Cleansers</title>
  </head>
  <body class="bg-[#f4f1ed] text-[#27211c] selection:bg-[#d8c4b4] selection:text-[#241d18]">
    <main class="mx-auto max-w-[1240px] px-3 py-3 md:px-6 md:py-6">
      <header class="sticky top-3 z-30 rounded-[0.9rem] border border-[#e6dfd8] bg-white/94 px-3 py-3 shadow-[0_10px_26px_rgba(56,37,24,0.05)] backdrop-blur md:px-6">
        <div class="flex items-center justify-between gap-3 md:hidden">
          <div class="flex min-w-0 items-center gap-3">
            <img src={TFG_LOGO} alt="TFG logo" class="h-10 w-10 shrink-0" />
            <p class="min-w-0 text-sm font-medium leading-5 text-[#51463d]">Let’s talk skincare - Cleansers</p>
          </div>

          <details class="relative shrink-0 md:hidden" data-mobile-nav>
            <summary class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[#e8e0d8] bg-[#faf8f6] text-[#51463d] transition hover:bg-[#f4efea] [&::-webkit-details-marker]:hidden">
              <span class="sr-only">Toggle lesson navigation</span>
              <span aria-hidden="true" class="flex flex-col gap-[0.28rem]">
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
                <span class="block h-[2px] w-5 rounded-full bg-current"></span>
              </span>
            </summary>

            <div class="absolute right-0 top-[calc(100%+0.75rem)] z-20 w-64 max-w-[calc(100vw-1.5rem)] overflow-hidden rounded-[0.9rem] border border-[#e6dfd8] bg-white p-2 shadow-[0_14px_36px_rgba(56,39,27,0.09)]">
              <div class="flex flex-col gap-1.5 text-sm text-[#51463d]">
                {navItems.map((item) => (
                  <a href={item.href} class="rounded-[0.75rem] px-4 py-3 transition hover:bg-[#f4efea]" data-mobile-nav-link>{item.label}</a>
                ))}
              </div>
            </div>
          </details>
        </div>

        <div class="hidden md:flex md:items-center md:justify-between md:gap-6">
          <div class="flex items-center gap-4">
            <img src={TFG_LOGO} alt="TFG logo" class="h-10 w-10" />
            <p class="text-sm font-medium text-[#51463d]">Let’s talk skincare - Cleansers</p>
          </div>
          <div class="flex flex-wrap gap-2 text-sm text-[#51463d]">
            {navItems.map((item) => (
              <a href={item.href} class="rounded-full border border-[#e8e0d8] bg-[#faf8f6] px-4 py-2 hover:bg-[#f4efea]">{item.label}</a>
            ))}
          </div>
        </div>
      </header>

      <section class="relative mt-4 overflow-hidden rounded-[1rem] border border-[#e3ddd7] bg-[#f6f1ec] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
        <img src={courseHero.src} alt="Beauty course hero image" class="absolute inset-0 h-full w-full object-cover object-center md:inset-y-0 md:left-auto md:right-0 md:w-[50%] md:object-right" />
        <div class="absolute inset-0 bg-[linear-gradient(180deg,_rgba(246,241,236,0.6)_0%,_rgba(246,241,236,1)_100%)] md:inset-y-0 md:left-auto md:right-[10%] md:w-[40%] md:bg-[linear-gradient(90deg,_#f6f1ec_0%,_rgba(246,241,236,0)_100%)]"></div>
        <div class="relative px-4 py-10 md:px-10 md:py-20 lg:px-12 lg:py-24">
          <img src={OBC_LOGO} alt="Beauty Co. logo" class="h-[4.8rem] w-auto md:h-24" />
          <div class="mt-6 inline-flex items-center gap-3 rounded-full border border-[#e6ddd5] bg-white/88 px-4 py-2 backdrop-blur md:mt-8">
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[#8f7968]">Module 2</span>
          </div>
          <h1 class="mt-10 max-w-md text-4xl font-semibold tracking-[-0.03em] text-[#2f2924] md:mt-12 md:text-6xl">Let’s talk skincare - Cleansers</h1>
        </div>
      </section>

      <section class="mt-6 space-y-6">
        {lessons.map((lesson) => (
          <section id={lesson.id} class="overflow-hidden rounded-[1rem] border border-[#e3ddd7] bg-[#fbfaf8] shadow-[0_14px_36px_rgba(56,39,27,0.05)]">
            <div class="overflow-hidden">
              <img
                src={lesson.bannerImage ? lesson.bannerImage.src : softBanner(lesson.theme.accent, lesson.theme.soft, lesson.theme.deep)}
                alt={`${lesson.title} banner`}
                class={`h-[220px] w-full object-cover md:h-[280px] lg:h-[320px] ${lesson.id === "pre-cleanse" ? "object-right" : ""}`}
              />
            </div>

            <div class="px-4 py-5 md:px-8 md:py-8 lg:px-10">
              <div class="space-y-4">
                <article class="p-3 md:p-5 lg:p-6">
                  <div class="lg:grid lg:grid-cols-[minmax(0,0.82fr)_minmax(0,1.58fr)] lg:items-center lg:gap-10">
                    <div class={`lg:flex lg:max-w-[34rem] lg:flex-col lg:justify-center ${lesson.id === "hydrating-cream-cleanser" ? "lg:pr-10" : ""}`}>
                      <p class="flex flex-wrap items-baseline gap-x-2 gap-y-1 text-[1.125rem] font-semibold uppercase leading-[1.25] tracking-[0.18em] text-[#8f7968]">
                        <span class="shrink-0">{lesson.lesson} -</span>
                        <span class={lesson.id === "hydrating-cream-cleanser" ? "" : "md:whitespace-nowrap"}>{lesson.title}</span>
                      </p>
                      <p class="mt-3 text-[1.5rem] font-semibold leading-[1.2] tracking-[-0.02em] text-[#2f2924] md:text-[2.1875rem]">{stripNumbering(lesson.productName)}</p>

                      {lesson.looksLike && <p class="mt-4 text-[1.125rem] leading-8 text-[#504841]">{lesson.looksLike}</p>}
                    </div>

                    {lesson.productImages?.length ? (
                      <div class="mt-4 grid grid-cols-2 gap-3 md:mt-5 md:gap-5 lg:mt-0 lg:gap-7">
                        {lesson.productImages.map((productImage, index) => (
                          <div class="aspect-square w-full overflow-hidden rounded-[0.8rem] bg-[#f6f2ee]">
                            <img src={productImage.src} alt={`${lesson.title} product image ${index + 1}`} class="h-full w-full object-cover" />
                          </div>
                        ))}
                      </div>
                    ) : (
                      <div class="mt-4 overflow-hidden rounded-[0.8rem] bg-[#f6f2ee] md:mt-5 lg:mt-0">
                        <img src={softProduct(lesson.theme.accent, lesson.theme.soft, lesson.theme.deep, lesson.visual)} alt={`${lesson.title} visual`} class="h-full w-full object-cover" />
                      </div>
                    )}
                  </div>
                </article>

                <article class="rounded-[0.95rem] border border-[#e7dfd8] bg-white p-4 md:p-5">
                    <h3 class="mt-3 text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(lesson.overviewHeading)}</h3>
                    <div class="mt-4 space-y-4 text-[1.125rem] leading-8 text-[#4e4741]">
                      {lesson.overview.map((paragraph) => <p>{paragraph}</p>)}
                      {lesson.overviewBullets && (
                        <ul class="list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                          {lesson.overviewBullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                        </ul>
                      )}
                      {lesson.overviewExtraParagraphs?.map((paragraph) => <p>{paragraph}</p>)}
                    </div>
                </article>

                <div class="grid gap-4 md:grid-cols-2">
                  {(() => {
                    const lessonSections = getRegularSectionsAfterOverview(lesson);
                    const lessonSectionSpanClasses = getSectionSpanClasses(lessonSections);

                    return lessonSections.map((section, index) => (
                      <article class={`rounded-[0.95rem] bg-white/50 p-4 shadow-[0_10px_24px_rgba(56,39,27,0.035)] md:p-5 ${lessonSectionSpanClasses[index]}`}>
                        {section.heading && <h3 class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(section.heading)}</h3>}
                        {section.label && !section.heading && <p class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{section.label}</p>}
                        {section.label && section.heading && <p class="mt-3 text-[1.125rem] text-[#4e4741]">{section.label}</p>}
                        {section.paragraph && <p class="mt-4 text-[1.125rem] leading-8 text-[#4e4741]">{section.paragraph}</p>}

                        {section.bullets && (
                          <ul class="mt-4 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                            {section.bullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                          </ul>
                        )}

                        {section.subsections && (
                          <div class="mt-4 grid gap-4 md:grid-cols-2">
                            {section.subsections.map((subsection) => (
                              <div class="rounded-[0.8rem] bg-white/50 p-3 shadow-[0_8px_18px_rgba(56,39,27,0.03)] md:p-4">
                                {subsection.label && <p class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{subsection.label}</p>}

                                {subsection.bullets && (
                                  <ul class="mt-2 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                                    {subsection.bullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                                  </ul>
                                )}

                                {subsection.paragraph && <p class="mt-3 text-[1.125rem] leading-8 text-[#4e4741]">{subsection.paragraph}</p>}
                              </div>
                            ))}
                          </div>
                        )}
                      </article>
                    ));
                  })()}
                </div>

                {(() => {
                  const howToSellSection = getHowToSellSection(lesson);

                  if (!lesson.topTip && !howToSellSection) return null;

                  return (
                    <div class="space-y-4">
                      {howToSellSection && (
                        <article class="rounded-[0.95rem] border border-[#c9bfaa] p-4 text-[#2f2924] md:p-5" style={`background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${lesson.theme.accent}26 100%);`}>
                          <div class="flex items-center gap-2 text-[1.5rem] font-semibold tracking-[-0.02em] text-[#6e6054]">
                            <img src={topTipIcon} alt="" aria-hidden="true" class="w-auto shrink-0" style="height:1.1em;" />
                            <p class="leading-none">{howToSellSection.heading ? stripNumbering(howToSellSection.heading) : "How to sell"}</p>
                          </div>
                          {howToSellSection.label && <p class="mt-3 text-[1.125rem] text-[#4e4741]">{howToSellSection.label}</p>}
                          {howToSellSection.paragraph && <p class="mt-4 text-[1.125rem] leading-8 text-[#4e4741]">{howToSellSection.paragraph}</p>}

                          {howToSellSection.bullets && (
                            <ul class="mt-4 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                              {howToSellSection.bullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                            </ul>
                          )}

                          {howToSellSection.subsections && (
                            <div class="mt-4 grid gap-4 md:grid-cols-2">
                              {howToSellSection.subsections.map((subsection) => (
                                <div class="rounded-[0.8rem] border border-[#ddd0c2] bg-transparent p-4">
                                  {subsection.label && <p class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{subsection.label}</p>}

                                  {subsection.bullets && (
                                    <ul class="mt-2 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                                      {subsection.bullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                                    </ul>
                                  )}

                                  {subsection.paragraph && <p class="mt-3 text-[1.125rem] leading-8 text-[#4e4741]">{subsection.paragraph}</p>}
                                </div>
                              ))}
                            </div>
                          )}
                        </article>
                      )}

                      {lesson.topTip && (
                        <article class="rounded-[0.95rem] border border-[#c9bfaa] p-4 text-[#2f2924] md:p-5" style={`background: linear-gradient(135deg, rgba(255,255,255,0.96) 0%, ${lesson.theme.accent}26 100%);`}>
                          <div class="flex items-center gap-2 text-[1.5rem] font-semibold tracking-[-0.02em] text-[#6e6054]">
                            <img src={topTipIcon} alt="" aria-hidden="true" class="w-auto shrink-0" style="height:1.1em;" />
                            <p class="leading-none">Top Tip</p>
                          </div>
                          <p class="mt-3 text-[1.125rem] leading-8 text-[#4e4741]">{lesson.topTip}</p>
                        </article>
                      )}
                    </div>
                  );
                })()}

                {(() => {
                  const whenToRecommendSection = getWhenToRecommendSection(lesson);

                  if (!whenToRecommendSection) return null;

                  return (
                    <article class="p-4 md:p-5">
                      {whenToRecommendSection.heading && <h3 class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{stripNumbering(whenToRecommendSection.heading)}</h3>}
                      {whenToRecommendSection.label && !whenToRecommendSection.heading && <p class="text-[1.5rem] font-semibold tracking-[-0.02em] text-[#2f2924]">{whenToRecommendSection.label}</p>}
                      {whenToRecommendSection.label && whenToRecommendSection.heading && <p class="mt-3 text-[1.125rem] text-[#4e4741]">{whenToRecommendSection.label}</p>}
                      {whenToRecommendSection.paragraph && <p class="mt-4 text-[1.125rem] leading-8 text-[#4e4741]">{whenToRecommendSection.paragraph}</p>}

                      {whenToRecommendSection.bullets && (
                        <ul class="mt-4 list-disc space-y-2 pl-5 text-[1.125rem] leading-8 text-[#4e4741] marker:text-[#605248]">
                          {whenToRecommendSection.bullets.map((bullet) => <li>{withBulletPeriod(bullet)}</li>)}
                        </ul>
                      )}
                    </article>
                  );
                })()}

                <article class="rounded-[0.95rem] border border-transparent p-4 text-white md:p-6" style={`background: linear-gradient(135deg, ${lesson.theme.deep} 0%, ${lesson.theme.accent} 100%);`}>
                    <div class="grid gap-6 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-start">
                      <div class="min-w-0">
                        <p class="inline-flex rounded-full bg-white/18 px-4 py-2 text-sm font-semibold">{lesson.assessment.title}</p>
                        <p class="mt-4 text-[1.38rem] font-semibold leading-[1.45] tracking-[-0.02em]">{lesson.assessment.scenario}</p>
                        <p class="mt-5 text-lg font-semibold">{lesson.assessment.scene}</p>
                        <p class="mt-3 text-[1rem] leading-8 text-white/92">{lesson.assessment.customerIntro}</p>

                        <div class="mt-5 flex items-start gap-4">
                          <div class="avatar placeholder shrink-0">
                            <div class="flex w-12 items-center justify-center rounded-full bg-[#2c241f] text-white">
                              <span class="text-lg font-semibold">C</span>
                            </div>
                          </div>
                          <div class="relative max-w-[32rem] rounded-[1.15rem] bg-white px-4 py-3 text-[#2a231f] before:absolute before:left-[-0.35rem] before:top-5 before:h-4 before:w-4 before:rotate-45 before:rounded-[0.15rem] before:bg-white before:content-['']">
                            {lesson.assessment.customerQuote}
                          </div>
                        </div>

                        <p class="mt-4 text-[1rem] leading-8 text-white/95">{lesson.assessment.goal}</p>
                      </div>

                    <div class="overflow-hidden rounded-[0.9rem] border border-white/18 bg-white/92 text-[#2a231f] shadow-[0_10px_28px_rgba(40,27,20,0.10)] lg:self-start">
                      <div class="px-4 py-4 md:px-5 md:py-5">
                        <div class="quiz" data-quiz>
                          <div class="flex items-center justify-between gap-4">
                            <p class="text-sm uppercase tracking-[0.18em] text-[#8f7968]">Knowledge check</p>
                            <p class="quiz-progress text-sm text-[#5b4c41]"></p>
                          </div>

                          <div class="mt-4 space-y-4">
                            {lesson.assessment.quiz.map((question, questionIndex) => (
                              <div class={`quiz-step rounded-[0.9rem] border border-[#ebe3db] bg-[#fbf8f5] p-4 md:p-5 ${questionIndex !== 0 ? "hidden" : ""}`} data-step data-correct={question.correct}>
                                <p class="pr-2 text-[1.05rem] font-semibold leading-7 text-[#2f2924]">
                                  {questionIndex + 1}. {question.question}
                                </p>

                                <div class="mt-4 space-y-3">
                                  {question.options.map((option, optionIndex) => (
                                    <label class="flex cursor-pointer gap-3 rounded-[0.8rem] border border-[#efe6df] bg-white px-4 py-3 text-sm leading-6 text-[#4d433d] transition hover:border-[#d5c3b7] hover:bg-[#fcfaf8]">
                                      <input type="radio" name={`${lesson.id}-q${questionIndex}`} value={optionIndex} class="radio radio-sm mt-1 border-[#9f866f] text-[#9f866f] checked:bg-[#9f866f] checked:text-[#9f866f]" />
                                      <span>{option}</span>
                                    </label>
                                  ))}
                                </div>

                                <p class="quiz-feedback mt-4 hidden rounded-[0.8rem] bg-[#f5efe9] px-4 py-3 text-sm leading-6 text-[#4b4039]"></p>
                              </div>
                            ))}
                          </div>

                          <div class="mt-5 flex flex-wrap items-center gap-3">
                            <button type="button" class="quiz-prev btn h-auto min-h-0 rounded-full border border-[#d8cbc0] bg-white px-5 py-3 text-[#2b2420] shadow-none hover:bg-[#faf7f4]">Previous</button>
                            <button type="button" class="quiz-check btn h-auto min-h-0 rounded-full border-none bg-[#2b2420] px-5 py-3 text-white shadow-none hover:bg-black">Check this question</button>
                            <button type="button" class="quiz-next btn h-auto min-h-0 rounded-full border-none bg-[#2b2420] px-5 py-3 text-white shadow-none hover:bg-black">Next</button>
                            <button type="button" class="quiz-reset btn h-auto min-h-0 rounded-full border border-[#d8cbc0] bg-white px-5 py-3 text-[#2b2420] shadow-none hover:bg-[#faf7f4]">Reset</button>
                            <p class="quiz-result text-sm text-[#5b4c41]">Choose an answer, then check the question.</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </article>
              </div>
            </div>
          </section>
        ))}
      </section>
    </main>

    <script is:inline>
      const mobileNavs = document.querySelectorAll('[data-mobile-nav]');

      document.addEventListener('click', (event) => {
        mobileNavs.forEach((menu) => {
          if (!menu.contains(event.target)) {
            menu.removeAttribute('open');
          }
        });
      });

      mobileNavs.forEach((menu) => {
        menu.querySelectorAll('[data-mobile-nav-link]').forEach((link) => {
          link.addEventListener('click', () => {
            menu.removeAttribute('open');
          });
        });
      });

      const quizzes = document.querySelectorAll('[data-quiz]');

      quizzes.forEach((quiz) => {
        const steps = Array.from(quiz.querySelectorAll('[data-step]'));
        const progress = quiz.querySelector('.quiz-progress');
        const prevButton = quiz.querySelector('.quiz-prev');
        const nextButton = quiz.querySelector('.quiz-next');
        const checkButton = quiz.querySelector('.quiz-check');
        const resetButton = quiz.querySelector('.quiz-reset');
        const result = quiz.querySelector('.quiz-result');

        let current = 0;

        const updateView = () => {
          steps.forEach((step, index) => {
            step.classList.toggle('hidden', index !== current);
          });

          if (progress) {
            progress.textContent = `Question ${current + 1} of ${steps.length}`;
          }

          if (prevButton) {
            prevButton.disabled = current === 0;
            prevButton.classList.toggle('opacity-50', current === 0);
            prevButton.classList.toggle('pointer-events-none', current === 0);
          }

          if (nextButton) {
            nextButton.textContent = current === steps.length - 1 ? 'Finish review' : 'Next';
          }
        };

        const checkCurrentQuestion = () => {
          const step = steps[current];
          const selected = step.querySelector('input[type="radio"]:checked');
          const feedback = step.querySelector('.quiz-feedback');
          const correct = step.dataset.correct;

          step.classList.remove('ring-2', 'ring-[#b19a84]', 'ring-red-200');

          if (!selected) {
            if (feedback) {
              feedback.textContent = 'Select an answer first.';
              feedback.classList.remove('hidden');
            }
            if (result) {
              result.textContent = 'Select an answer first.';
            }
            return;
          }

          const isCorrect = selected.value === correct;

          if (feedback) {
            feedback.textContent = isCorrect ? 'Correct.' : 'Incorrect.';
            feedback.classList.remove('hidden');
          }

          if (isCorrect) {
            step.classList.add('ring-2', 'ring-[#b19a84]');
            if (result) {
              result.textContent = 'Correct.';
            }
          } else {
            step.classList.add('ring-2', 'ring-red-200');
            if (result) {
              result.textContent = 'Incorrect.';
            }
          }
        };

        const resetQuiz = () => {
          current = 0;

          steps.forEach((step) => {
            step.querySelectorAll('input[type="radio"]').forEach((input) => {
              input.checked = false;
            });

            step.classList.remove('ring-2', 'ring-[#b19a84]', 'ring-red-200');

            const feedback = step.querySelector('.quiz-feedback');
            if (feedback) {
              feedback.textContent = '';
              feedback.classList.add('hidden');
            }
          });

          if (result) {
            result.textContent = 'Choose an answer, then check the question.';
          }

          updateView();
        };

        checkButton?.addEventListener('click', checkCurrentQuestion);

        nextButton?.addEventListener('click', () => {
          if (current < steps.length - 1) {
            current += 1;
            updateView();
          } else if (result) {
            result.textContent = 'You have reached the end of this quiz.';
          }
        });

        prevButton?.addEventListener('click', () => {
          if (current > 0) {
            current -= 1;
            updateView();
          }
        });

        resetButton?.addEventListener('click', resetQuiz);

        updateView();
      });
    </script>
  </body>
</html>

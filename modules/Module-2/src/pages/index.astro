function stripNumbering(text) {
  if (!text) return text;
  const parts = text.split(") ");
  if (parts.length < 2) return text;
  const first = parts[0];
  const isNumbered = first.split(".").every((part) => part && [...part].every((char) => char >= "0" && char <= "9"));
  return isNumbered ? parts.slice(1).join(") ") : text;
}

function withBulletPeriod(text) {
  if (!text) return text;
  const trimmed = text.trim();
  const trailingQuoteMatch = trimmed.match(/[”"]$/);
  const trailingQuote = trailingQuoteMatch ? trailingQuoteMatch[0] : "";
  const core = trailingQuote ? trimmed.slice(0, -1).trimEnd() : trimmed;

  if (/[.!?:]$/.test(core)) return trimmed;
  if (core.endsWith(",")) return `${core.slice(0, -1)}.${trailingQuote}`;
  return `${core}.${trailingQuote}`;
}

function isHowToSellSection(section) {
  return stripNumbering(section.heading || "").toLowerCase().includes("how to sell");
}

function isWhenToRecommendSection(section) {
  return stripNumbering(section.heading || "").toLowerCase().includes("when to recommend");
}

function getHowToSellSection(lesson) {
  return lesson.sections.find((section) => isHowToSellSection(section));
}

function getWhenToRecommendSection(lesson) {
  return lesson.sections.find((section) => isWhenToRecommendSection(section));
}

function getRegularSectionsAfterOverview(lesson) {
  return lesson.sections.filter(
    (section) => !isHowToSellSection(section) && !isWhenToRecommendSection(section)
  );
}

function getSectionSpanClasses(sections) {
  const classes = Array(sections.length).fill("");
  let openHalfWidthIndex = null;

  sections.forEach((section, index) => {
    if (section.subsections) {
      if (openHalfWidthIndex !== null) {
        classes[openHalfWidthIndex] = "md:col-span-2";
        openHalfWidthIndex = null;
      }

      classes[index] = "md:col-span-2";
      return;
    }

    if (openHalfWidthIndex === null) {
      openHalfWidthIndex = index;
    } else {
      openHalfWidthIndex = null;
    }
  });

  if (openHalfWidthIndex !== null) {
    classes[openHalfWidthIndex] = "md:col-span-2";
  }

  return classes;
}

function svgToDataUri(svg) {
  return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
}

